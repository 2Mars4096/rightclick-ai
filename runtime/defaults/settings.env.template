# Right Click Calendar settings
# Edit this file, then use the "Add to Calendar" Quick Action on selected text.

PROVIDER=__DEFAULT_PROVIDER__
CALENDAR_NAME=
TIMEZONE=__SYSTEM_TIMEZONE__
DEFAULT_EVENT_DURATION_MINUTES=60
REQUEST_TIMEOUT_SECONDS=120
NOTIFY_ON_SUCCESS=1
NOTIFY_ON_FAILURE=1

# OpenAI-compatible providers
# Works with OpenAI and most OpenAI-style gateways.
# When saved from the native app, API keys are stored in the macOS Keychain.
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_AUTH_HEADER=Authorization
OPENAI_AUTH_SCHEME=Bearer

# Anthropic
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VERSION=2023-06-01

# Gemini
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Custom provider
# The command receives the rendered prompt on stdin and must print model output
# or normalized JSON to stdout.
CUSTOM_PROVIDER_COMMAND=
